<Window x:Class="Poly4.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine de Polymérisation"
        Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A2332"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Taskbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ TASKBAR ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource TaskBarStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo -->
                    <ColumnDefinition Width="*"/>
                    <!-- Title -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- Logo Zone -->
                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="8"
                        Background="#00C4FF22" BorderBrush="#00C4FF55" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="22" Foreground="#00C4FF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="MACHINE DE POLYMÉRISATION"
                               FontFamily="Segoe UI Light" FontSize="18" FontWeight="Light"
                               Foreground="#E8F4FD"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="SYSTÈME DE CONTRÔLE v1.0"
                               FontFamily="Segoe UI" FontSize="9"
                               Foreground="#7A9BBE"
                               HorizontalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>

                <!-- Settings Button -->
                <Button Grid.Column="2" x:Name="BtnSettings"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="42" Height="42" Padding="0"
                        Click="BtnSettings_Click"
                        VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="18" Foreground="#7A9BBE"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ CONTENT ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="30,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Parameter Cards -->
            <StackPanel Grid.Row="0">

                <!-- Card: Nombre de Cycles -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NOMBRE DE CYCLES"
                                       FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#7A9BBE" Margin="0,0,0,10"/>
                            <Slider x:Name="SliderCycles"
                                    Style="{StaticResource SliderStyle}"
                                    Minimum="1" Maximum="10" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderCycles_ValueChanged"
                                    Margin="0,8,20,4"/>
                            <!-- Tick labels -->
                            <Grid Margin="0,4,20,0">
                                <TextBlock Text="1" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Left"/>
                                <TextBlock Text="5" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Center"/>
                                <TextBlock Text="10" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1923" CornerRadius="8"
                                BorderBrush="#00C4FF44" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="100" Height="58">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCycles" Text="1"
                                           FontFamily="Segoe UI Light" FontSize="32"
                                           Foreground="#00C4FF" HorizontalAlignment="Center"/>
                                <TextBlock Text="cycle(s)" FontSize="9" Foreground="#7A9BBE"
                                           HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Taille -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TAILLE"
                                       FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#7A9BBE" Margin="0,0,0,10"/>
                            <Slider x:Name="SliderTaille"
                                    Style="{StaticResource SliderStyle}"
                                    Minimum="5" Maximum="30" Value="5"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderTaille_ValueChanged"
                                    Margin="0,8,20,4"/>
                            <Grid Margin="0,4,20,0">
                                <TextBlock Text="5" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Left"/>
                                <TextBlock Text="15" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Center"/>
                                <TextBlock Text="30" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1923" CornerRadius="8"
                                BorderBrush="#00C4FF44" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="100" Height="58">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTaille" Text="5"
                                           FontFamily="Segoe UI Light" FontSize="32"
                                           Foreground="#00C4FF" HorizontalAlignment="Center"/>
                                <TextBlock Text="mm" FontSize="9" Foreground="#7A9BBE"
                                           HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Options (Checkboxes) -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="OPTIONS"
                                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#7A9BBE" Margin="0,0,0,14"/>
                        <CheckBox x:Name="ChkNettoyageCycle"
                                  Style="{StaticResource CheckBoxStyle}"
                                  Content="Nettoyage en fin de cycle"
                                  Checked="Options_Changed" Unchecked="Options_Changed"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkNettoyageSeul"
                                  Style="{StaticResource CheckBoxStyle}"
                                  Content="Nettoyage seul"
                                  Checked="Options_Changed" Unchecked="Options_Changed"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Bottom Bar: Estimation + Lancer -->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Temps estimé -->
                <Border Grid.Column="0" Background="#1E2D40" CornerRadius="10"
                        Padding="20,14" BorderBrush="#00C4FF22" BorderThickness="1"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="16" Foreground="#7A9BBE"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="TEMPS ESTIMÉ"
                                       FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#7A9BBE"/>
                            <TextBlock x:Name="TxtTempsEstime" Text="— min —"
                                       FontFamily="Segoe UI Light" FontSize="22"
                                       Foreground="#E8F4FD"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lancer Button -->
                <Button Grid.Column="1" x:Name="BtnLancer"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160" Height="58"
                        FontSize="16" FontWeight="Bold"
                        Click="BtnLancer_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶  " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="LANCER" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
