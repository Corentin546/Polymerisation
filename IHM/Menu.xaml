<Window x:Class="Poly4.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine de Polymérisation"
        Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A2332"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Taskbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ TASKBAR ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource TaskBarStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo -->
                    <ColumnDefinition Width="*"/>
                    <!-- Title -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- Logo Zone -->
                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="8"
                        Background="#00C4FF22" BorderBrush="#00C4FF55" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="22" Foreground="#00C4FF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="MACHINE DE POLYMÉRISATION"
                               FontFamily="Segoe UI Light" FontSize="18" FontWeight="Light"
                               Foreground="#E8F4FD"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="SYSTÈME DE CONTRÔLE
                               "
                               FontFamily="Segoe UI" FontSize="9"
                               Foreground="#7A9BBE"
                               HorizontalAlignment="Center" Margin="0,1,0,0" Height="15" Width="104"/>
                </StackPanel>

                <!-- Settings Button -->
                <Button Grid.Column="2" x:Name="BtnSettings"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="46" Height="46" Padding="11"
                        Click="BtnSettings_Click"
                        ToolTip="Paramètres"
                        VerticalAlignment="Center">
                    <Viewbox Stretch="Uniform">
                        <Path Fill="#7A9BBE"
                              Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ CONTENT ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="30,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Parameter Cards -->
            <StackPanel Grid.Row="0">

                <!-- Card: Nombre de Cycles -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NOMBRE DE CYCLES"
                                       FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#7A9BBE" Margin="0,0,0,10"/>
                            <Slider x:Name="SliderCycles"
                                    Style="{StaticResource SliderStyle}"
                                    Minimum="1" Maximum="10" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderCycles_ValueChanged"
                                    Margin="0,8,0,4"/>
                            <!-- Tick labels -->
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1"  FontSize="10" Foreground="#7A9BBE55"/>
                                <TextBlock Grid.Column="1" Text="5"  FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="10" FontSize="10" Foreground="#7A9BBE55"/>
                            </Grid>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1923" CornerRadius="8"
                                BorderBrush="#00C4FF44" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="100" Height="58">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCycles" Text="1"
                                           FontFamily="Segoe UI Light" FontSize="32"
                                           Foreground="#00C4FF" HorizontalAlignment="Center"/>
                                <TextBlock Text="cycle(s)" FontSize="9" Foreground="#7A9BBE"
                                           HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Taille -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TAILLE DE LA PIÈCE"
                                       FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#7A9BBE" Margin="0,0,0,10"/>
                            <Slider x:Name="SliderTaille"
                                    Style="{StaticResource SliderStyle}"
                                    Minimum="1" Maximum="30" Value="10"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderTaille_ValueChanged"
                                    Margin="0,8,0,4"/>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1"  FontSize="10" Foreground="#7A9BBE55"/>
                                <TextBlock Grid.Column="1" Text="15" FontSize="10" Foreground="#7A9BBE55" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="30" FontSize="10" Foreground="#7A9BBE55"/>
                            </Grid>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1923" CornerRadius="8"
                                BorderBrush="#00C4FF44" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="100" Height="58">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTaille" Text="10"
                                           FontFamily="Segoe UI Light" FontSize="32"
                                           Foreground="#00C4FF" HorizontalAlignment="Center"/>
                                <TextBlock Text="cm" FontSize="9" Foreground="#7A9BBE"
                                           HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Options (RadioButtons exclusifs) -->
                <Border Background="#1E2D40" CornerRadius="10" Padding="24,18"
                        BorderBrush="#00C4FF22" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="OPTIONS DE NETTOYAGE"
                                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#7A9BBE" Margin="0,0,0,14"/>
                        <RadioButton x:Name="ChkAucunNettoyage"
                                     GroupName="Nettoyage"
                                     Style="{StaticResource RadioButtonStyle}"
                                     Content="Aucun nettoyage"
                                     IsChecked="True"
                                     Checked="Options_Changed"
                                     Margin="0,0,0,10"/>
                        <RadioButton x:Name="ChkNettoyageCycle"
                                     GroupName="Nettoyage"
                                     Style="{StaticResource RadioButtonStyle}"
                                     Content="Nettoyage en fin de cycle"
                                     Checked="Options_Changed"
                                     Margin="0,0,0,10"/>
                        <RadioButton x:Name="ChkNettoyageSeul"
                                     GroupName="Nettoyage"
                                     Style="{StaticResource RadioButtonStyle}"
                                     Content="Nettoyage seul (sans cycles)"
                                     Checked="Options_Changed"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Bottom Bar: Estimation + Lancer -->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Temps estimé -->
                <Border Grid.Column="0" Background="#1E2D40" CornerRadius="10"
                        Padding="20,14" BorderBrush="#00C4FF22" BorderThickness="1"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="16" Foreground="#7A9BBE"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="TEMPS ESTIMÉ"
                                       FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#7A9BBE"/>
                            <TextBlock x:Name="TxtTempsEstime" Text="— min —"
                                       FontFamily="Segoe UI Light" FontSize="22"
                                       Foreground="#E8F4FD"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lancer Button -->
                <Button Grid.Column="1" x:Name="BtnLancer"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160" Height="58"
                        FontSize="16" FontWeight="Bold"
                        Click="BtnLancer_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶  " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="LANCER" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
